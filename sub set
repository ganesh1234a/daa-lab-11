#include <bits/stdc++.h>
using namespace std;

void subsetSum(vector<int>& arr, int index, int target, vector<int>& current) {
    // If target becomes 0 → valid subset found
    if (target == 0) {
        cout << "{ ";
        for (int x : current) cout << x << " ";
        cout << "}" << endl;
        return;
    }

    // If index out of range or target becomes negative
    if (index >= arr.size() || target < 0)
        return;

    // Include current element
    current.push_back(arr[index]);
    subsetSum(arr, index + 1, target - arr[index], current);

    // Exclude current element (backtrack)
    current.pop_back();
    subsetSum(arr, index + 1, target, current);
}

int main() {
    vector<int> arr = {2, 3, 5, 6, 8};
    int target = 10;

    vector<int> current;
    cout << "Subsets with sum " << target << " are:\n";

    subsetSum(arr, 0, target, current);

    return 0;
}
